# .env.example — LinkedIn AI Daily Post Automation
# ✅ Safe to commit — no real secrets here.
# Copy this file to .env and fill in your real values.
#
#   cp .env.example .env

# ── Groq (AI Post Generation) ─────────────────────────────────────────────────
# Get free key from: https://console.groq.com → API Keys
GROQ_API_KEY=

# ── Tavily (Topic Discovery & Research) ───────────────────────────────────────
# Get free key from: https://app.tavily.com → API Keys
TAVILY_API_KEY=

# ── Pollinations.AI (Image Generation) ───────────────────────────────────────
# Get key from: https://enter.pollinations.ai
POLLINATIONS_API_KEY=

# ── LinkedIn ──────────────────────────────────────────────────────────────────
# Run get_linkedin_token.py to generate these two values.
# Token expires every 60 days — re-run the script to refresh.
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=

# ── LinkedIn OAuth2 App Credentials (used only by get_linkedin_token.py) ──────
# Get from: https://developer.linkedin.com → Your App → Auth tab
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ── Google Sheets ─────────────────────────────────────────────────────────────
# The long ID from your Sheet URL: .../spreadsheets/d/THIS_PART/edit
GOOGLE_SHEET_ID=
# Path to service account JSON (relative to main.py)
GOOGLE_CREDENTIALS_FILE=credentials/your-service-account.json
SHEET_NAME=Posts

# ── Gmail SMTP ────────────────────────────────────────────────────────────────
GMAIL_SENDER=you@gmail.com
GMAIL_RECEIVER=you@gmail.com
# App Password (NOT login password) — myaccount.google.com > Security > App Passwords
GMAIL_APP_PASSWORD=

# ── Behaviour ─────────────────────────────────────────────────────────────────
POST_TIME=10:00
MAX_RETRIES=3
QUALITY_MIN_SCORE=6
